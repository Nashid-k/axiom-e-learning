# Search API Configuration
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
YOUTUBE_API_KEY=your_youtube_api_key

# Authentication & Security
AUTH_SECRET=generate-a-strong-random-secret-here
NEXTAUTH_SECRET=generate-another-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Groq AI API Keys (Rotation Pool)
# Note: Keys are rotated sequentially to handle rate limits.
# You need at least one key. Get yours at https://console.groq.com/
GROQ_API_KEY_1=gsk_your_groq_api_key_1
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/axiom?appName=Cluster0
